menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default y

if LED_SUBSYSTEM
    choice
    prompt "LED blink sleep time"
    default BLINK_SLEEP_1000MS

    config BLINK_SLEEP_250MS
        bool "250ms (fast)"
    
    config BLINK_SLEEP_500MS
        bool "500ms (normal)"

    config BLINK_SLEEP_1000MS
        bool "1s (medium)"

    config BLINK_SLEEP_2000MS
        bool "2s (slow)"
    endchoice

    config BLINK_SLEEP_TIME_MS 
        int  
        default 250 if BLINK_SLEEP_250MS
        default 500 if BLINK_SLEEP_500MS
        default 1000 if BLINK_SLEEP_1000MS
        default 2000 if BLINK_SLEEP_2000MS
        default 0 
        help
            Time between LED toggles in miliseconds.

    menuconfig ADVANCED_LED_SETTINGS
        bool "Advanced LED Settings"
        default n

    if ADVANCED_LED_SETTINGS
        config LED_BRIGHTNESS
            int "LED Brightness (0-100)"
            range 0 100
            default 100

        config LED_FADE_DURATION
            int "LED fade duration (ms)"
            range 0 5000
            default 500
    endif # ADVANCED_LED_SETTINGS
    
    menu "Expert Settings"
        visible if ADVANCED_LED_SETTINGS
            config ENABLE_LED_DEBUGGING
                bool "Enable LED debugging"
	            default n

            config CUSTOM_BLINK_PATTERN
                bool "Custom blink pattern"
                default n
    endmenu # Expert Settings
endif # LED_SUBSYSTEM

source "Kconfig.zephyr"